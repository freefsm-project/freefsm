package templates

import "fmt"

templ InvoiceShow(p InvoiceDetail) {
	@Layout("Invoice - "+p.Title) {
		<div style="display:flex;justify-content:space-between;align-items:center">
			<h1>{ p.Title }</h1>
			<div style="display:flex;gap:0.5rem">
				<a href={ templ.URL(fmt.Sprintf("/invoices/%d/edit", p.ID)) } role="button" class="outline">Edit</a>
				<form action={ templ.URL(fmt.Sprintf("/invoices/%d/delete", p.ID)) } method="post" style="display:inline" onsubmit="return confirm('Delete this invoice?')">
					<button class="outline contrast">Delete</button>
				</form>
			</div>
		</div>
		<table>
			<tbody>
				<tr><th>Customer</th><td><a href={ templ.URL(fmt.Sprintf("/customers/%d", p.CustomerID)) }>{ p.Customer }</a></td></tr>
				<tr><th>Status</th><td><mark>{ p.StatusName }</mark></td></tr>
				<tr><th>Invoice Date</th><td>{ p.InvoiceDate }</td></tr>
				<tr><th>Due Date</th><td>{ p.DueDate }</td></tr>
				<tr><th>Tax Rate</th><td>{ p.TaxRate }</td></tr>
			</tbody>
		</table>
		if p.Notes != "" {
			<h3>Notes</h3>
			<p>{ p.Notes }</p>
		}
		<p><a href="/invoices">&larr; Back to Invoices</a></p>
	}
}
