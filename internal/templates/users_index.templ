package templates

import "fmt"

templ UsersIndex(p UserListData) {
	@Layout("Users") {

		<div style="display:flex;justify-content:flex-end;margin-bottom:1rem">
			<a href="/users/new" role="button">New User</a>
		</div>
		<table>
			<thead>
				<tr><th>Name</th><th>Email</th><th>Role</th><th>Active</th><th></th></tr>
			</thead>
			<tbody>
				for _, u := range p.Users {
					<tr>
						<td><a href={ templ.URL(fmt.Sprintf("/users/%d", u.ID)) }>{ u.Name }</a></td>
						<td>{ u.Email }</td>
						<td><mark>{ u.Role }</mark></td>
						<td>
							if u.IsActive {
								Yes
							} else {
								No
							}
						</td>
						<td style="text-align:right">
							<a href={ templ.URL(fmt.Sprintf("/users/%d/edit", u.ID)) } role="button" class="outline small">Edit</a>
							<form action={ templ.URL(fmt.Sprintf("/users/%d/disable", u.ID)) } method="post" style="display:inline">
								<input type="hidden" name="csrf_token" value={ csrfToken(ctx) }/>
								<button class="outline contrast small">
									if u.IsActive {
										Disable
									} else {
										Enable
									}
								</button>
							</form>
						</td>
					</tr>
				}
			</tbody>
		</table>
		<div hx-get="/users/activity" hx-trigger="load" hx-swap="innerHTML" class="shared-widget">
			<p>Loading recent activity...</p>
		</div>
	}
}
