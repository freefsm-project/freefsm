package templates

import "fmt"

templ JobsIndex(p JobListPageData) {
	@Layout("Jobs") {

		<div class="list-toolbar">
			<form hx-get="/jobs" hx-target="#job-table-wrap" hx-swap="outerHTML" hx-push-url="true" hx-indicator="#search-spinner" style="display:flex;gap:0.5rem;align-items:center;flex:1">
				<input type="search" name="search" placeholder="Search by type or subtitle..."
					value={ p.Search } style="max-width:300px"
					hx-trigger="input changed delay:300ms"/>
				<select name="status_id" hx-trigger="change">
					<option value="0">All Statuses</option>
					for _, s := range p.Statuses {
						<option value={ fmt.Sprintf("%d", s.Value) } selected?={ p.StatusID == s.Value }>{ s.Label }</option>
					}
				</select>
				<span id="search-spinner" class="spinner htmx-indicator"></span>
			</form>
			if canManageOperational(ctx) {
				<a href="/jobs/new" role="button">New Job</a>
			}
		</div>
		@JobsTable(p)

		if canManageOperational(ctx) {
			<div hx-get="/jobs/activity" hx-trigger="load" hx-swap="innerHTML" style="margin-top:1.5rem">
				<p>Loading recent activity...</p>
			</div>
		}
	}
}

templ JobsTable(p JobListPageData) {
	<div id="job-table-wrap">
		<table>
			<thead>
				<tr>
					<th>Job</th>
					<th>Customer</th>
					<th>Status</th>
					<th>Scheduled</th>
					if canManageOperational(ctx) {
						<th>Billing</th>
						<th></th>
					}
				</tr>
			</thead>
			<tbody>
				if len(p.Jobs) == 0 {
					if canManageOperational(ctx) {
						<tr><td colspan="6" style="text-align:center">
							<p>No jobs found.</p>
							<a href="/jobs/new" role="button" class="outline" style="font-size:0.85rem">Create your first job</a>
						</td></tr>
					} else {
						<tr><td colspan="4" style="text-align:center">
							<p>No assigned jobs found.</p>
						</td></tr>
					}
				}
				for _, j := range p.Jobs {
					<tr>
						<td>
							<a href={ templ.URL(fmt.Sprintf("/jobs/%d", j.ID)) }>{ j.DisplayName }</a>
						</td>
						<td>{ j.Customer }</td>
						<td><span class="status-badge" style={ badgeStyle(j.StatusColor) }>{ j.StatusName }</span></td>
						<td>{ j.StartTime }</td>
						if canManageOperational(ctx) {
							<td>{ j.BillingType }</td>
							<td style="text-align:right">
								<a href={ templ.URL(fmt.Sprintf("/jobs/%d/edit", j.ID)) } role="button" class="outline small" aria-label={ fmt.Sprintf("Edit %s", j.DisplayName) }>Edit</a>
								<form action={ templ.URL(fmt.Sprintf("/jobs/%d/delete", j.ID)) } method="post" style="display:inline" onsubmit="return confirm('Delete this job?')">
									<input type="hidden" name="csrf_token" value={ csrfToken(ctx) }/>
									<button class="outline contrast small" aria-label={ fmt.Sprintf("Delete %s", j.DisplayName) }>Del</button>
								</form>
							</td>
						}
					</tr>
				}
			</tbody>
		</table>
		@Pagination(PaginationData{
			CurrentPage: p.Page,
			TotalPages:  p.TotalPages,
			BaseURL:     "/jobs",
			Target:      "#job-table-wrap",
		})
	</div>
}
