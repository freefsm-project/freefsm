package templates

import "fmt"

templ CustomFieldsWidget(p CustomFieldsWidgetData) {
	if len(p.Fields) > 0 {
		<div class="shared-widget">
			<h4>Custom Fields</h4>
			<div class="custom-fields-grid">
				for _, f := range p.Fields {
					<div>
						if p.EditMode {
							<label>
								<strong>{ f.Name }</strong>
								if f.Required {
									<small class="shared-widget-required"> *</small>
								}
								if f.FieldType == "text" {
									<input type="text" name={ fmt.Sprintf("custom_field_%d", f.DefinitionID) } value={ f.Value }/>
								} else if f.FieldType == "number" {
									<input type="number" name={ fmt.Sprintf("custom_field_%d", f.DefinitionID) } value={ f.Value } step="any"/>
								} else if f.FieldType == "date" {
									<input type="date" name={ fmt.Sprintf("custom_field_%d", f.DefinitionID) } value={ f.Value }/>
								} else if f.FieldType == "textarea" {
									<textarea name={ fmt.Sprintf("custom_field_%d", f.DefinitionID) } rows="3">{ f.Value }</textarea>
								} else if f.FieldType == "select" {
									<select name={ fmt.Sprintf("custom_field_%d", f.DefinitionID) }>
										<option value="">Select...</option>
										for _, o := range f.Options {
											<option value={ o } selected?={ f.Value == o }>{ o }</option>
										}
									</select>
								} else if f.FieldType == "checkbox" {
									<div class="custom-field-checkbox">
										<input type="hidden" name={ fmt.Sprintf("custom_field_%d", f.DefinitionID) } value=""/>
										<input type="checkbox" name={ fmt.Sprintf("custom_field_%d", f.DefinitionID) } value="true" checked?={ f.Value == "true" }/>
										<small>{ f.Name }</small>
									</div>
								}
							</label>
						} else {
							<label>
								<strong>{ f.Name }</strong>
							</label>
							if f.FieldType == "checkbox" {
								<p>
									if f.Value == "true" {
										Yes
									} else {
										No
									}
								</p>
							} else if f.FieldType == "date" && f.Value != "" {
								<p>{ displayDateValue(ctx, f.Value) }</p>
							} else if f.Value != "" {
								<p>{ f.Value }</p>
							} else {
								<p class="shared-widget-muted"><em>Not set</em></p>
							}
						}
					</div>
				}
			</div>
		</div>
	}
}
