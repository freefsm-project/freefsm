#!/bin/sh
#
# PROVIDE: freefsm
# REQUIRE: LOGIN postgresql
# KEYWORD: shutdown
#
# FreeBSD rc.d script for FreeFSM.
# Build the binary with GNU Make: gmake build
# Install with: gmake install-freebsd

. /etc/rc.subr

name="freefsm"
rcvar="freefsm_enable"

load_rc_config "$name"

: ${freefsm_enable:="NO"}
: ${freefsm_user:="freefsm"}
: ${freefsm_config:="/usr/local/etc/freefsm.conf"}

pidfile="/var/run/freefsm.pid"
command="/usr/local/bin/freefsm"
procname="freefsm"

start_cmd="freefsm_start"
stop_cmd="freefsm_stop"

freefsm_start() {
    echo "Starting ${name}."
    /usr/sbin/daemon -P ${pidfile} -u ${freefsm_user} \
        -o /var/log/freefsm/freefsm.log \
        ${command} -config ${freefsm_config}
}

freefsm_stop() {
    if [ -f "${pidfile}" ]; then
        read _pid < "${pidfile}"
        if kill -0 "${_pid}" 2>/dev/null; then
            echo "Stopping ${name}."
            kill "${_pid}" && wait_for_pids "${_pid}"
        fi
        rm -f "${pidfile}"
    else
        echo "${name} not running? (check ${pidfile})"
    fi
}

run_rc_command "$1"
